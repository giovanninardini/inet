<?xml version="1.0" encoding="ISO-8859-1"?>
<BGPConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="BGP.xsd">

    <TimerParams>
        <connectRetryTime> 120 </connectRetryTime>
        <holdTime> 180 </holdTime>
        <keepAliveTime> 680 </keepAliveTime>
        <startDelay> 2 </startDelay>
    </TimerParams>

    <AS id="65324">
        <Router interAddr="10.10.10.1" addressFamilies="ipv6-unicast">
            <Neighbor address="10.10.10.2" addressFamilies="ipv6-unicast"/>
        </Router>
    </AS>

    <AS id="65248">
        <Router interAddr="10.10.10.2" addressFamilies="ipv6-unicast">
            <Neighbor address="10.10.10.1" addressFamilies="ipv6-unicast"/>
        </Router>
    </AS>

   <Session id="1">
        <Router exterAddr="10.10.10.1"/>
        <Router exterAddr="10.10.10.2"/>
    </Session>

</BGPConfig>
